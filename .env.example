# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PHOTOS_BUCKET=plant-photos

# Private app access
BOTANIST_OWNER_PASSCODE=choose-a-shared-passcode
BOTANIST_SESSION_SALT=change-this-random-salt

# Optional read-only share route
BOTANIST_ENABLE_SHARE=false
BOTANIST_SHARE_TOKEN=family-read-only-secret-token

# App URL (used in docs/share references)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Future AI integration placeholders (not required for v1 mock mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=